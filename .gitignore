# Ignore everything
*

# But track these specific paths
!/.gitignore
!/app.py
!/btc_2015_2024.csv
!/requirements.txt
!/SECURITY.md

# MPA page modules
!/navigation/
!/navigation/*.py
!/navigation/__init__.py

# Image assets
!/img/
!/img/*.jpg
!/img/*.png

# Streamlit config (track config, ignore secrets)
!/.streamlit/
!/.streamlit/config.toml
.streamlit/secrets.toml

# Standard Python ignores
__pycache__/
*.pyc
.env
.venv/
